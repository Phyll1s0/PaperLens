{
  "name": "paperlens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "test": "node scripts/test.mjs",
    "dev": "node scripts/dev.mjs",
    "app": "node scripts/paperlens-app.mjs",
    "app:package": "node scripts/package-local-app.mjs",
    "start": "node server.js",
    "health": "node scripts/healthcheck.mjs",
    "storage:migrate:sqlite": "node scripts/migrate-json-to-sqlite.mjs",
    "storage:export:json": "node scripts/export-sqlite-to-json.mjs",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f paperlens",
    "service:start": "sh scripts/paperlens-service.sh start",
    "service:stop": "sh scripts/paperlens-service.sh stop",
    "service:restart": "sh scripts/paperlens-service.sh restart",
    "service:status": "sh scripts/paperlens-service.sh status",
    "launchd:install": "sh scripts/paperlens-launchd.sh install",
    "launchd:uninstall": "sh scripts/paperlens-launchd.sh uninstall",
    "launchd:status": "sh scripts/paperlens-launchd.sh status"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "katex": "^0.17.0"
  }
}
