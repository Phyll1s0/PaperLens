# PaperLens local configuration.
# Copy this file to .env and edit values as needed.

HOST=127.0.0.1
PORT=3000
PAPERLENS_PORT=3000

# Optional but strongly recommended for Docker/server deployments.
# When set, PaperLens requires this token before API, exports, and assets can be used.
PAPERLENS_ACCESS_TOKEN=

# Optional. If unset, PAPERLENS_ACCESS_TOKEN is also used to encrypt data/secrets.json.
PAPERLENS_SECRET_KEY=

# auto = macOS PDFKit fallback or Poppler when available; Docker should use poppler.
PAPERLENS_PDF_ENGINE=auto

# Local OCR for scanned PDFs. Default is English; use eng+chi_sim for Chinese/English papers.
PAPERLENS_OCR_LANGUAGE=eng
PAPERLENS_OCR_TIMEOUT_SECONDS=1800

# Optional. Leave empty if your network can reach model APIs directly.
# macOS/Linux local service example:
# PAPERLENS_PROXY_URL=http://127.0.0.1:7897
#
# Docker Desktop example:
# PAPERLENS_PROXY_URL=http://host.docker.internal:7897
PAPERLENS_PROXY_URL=

# Optional. Use only if Claude Code is installed in a non-standard location.
# PAPERLENS_CLAUDE_CLI=/opt/homebrew/bin/claude
PAPERLENS_CLAUDE_CLI=

# Analysis throughput. Defaults work for most users.
PAPERLENS_ANALYSIS_TARGET_MINUTES=20
PAPERLENS_ANALYSIS_BATCH_SIZE=12
PAPERLENS_ANALYSIS_CONCURRENCY=3
PAPERLENS_AGENT_ANALYSIS_BATCH_SIZE=8
PAPERLENS_AGENT_ANALYSIS_CONCURRENCY=2
PAPERLENS_ANALYSIS_FAILED_RETRY_BATCH_SIZE=2
