# PaperLens local configuration.
# Copy this file to .env and edit values as needed.

HOST=127.0.0.1
PORT=3000
PAPERLENS_PORT=3000

# Deployment mode: auto, local, lan, public, or docker.
# local keeps the default localhost workflow; lan/docker/public should use PAPERLENS_ACCESS_TOKEN.
PAPERLENS_DEPLOYMENT_MODE=auto
PAPERLENS_PUBLIC_URL=

# Optional but strongly recommended for Docker/server deployments.
# When set, PaperLens requires this token before API, exports, and assets can be used.
PAPERLENS_ACCESS_TOKEN=

# Optional. If unset, PAPERLENS_ACCESS_TOKEN is also used to encrypt data/secrets.json.
PAPERLENS_SECRET_KEY=

# auto = macOS PDFKit fallback or Poppler when available; Docker should use poppler.
PAPERLENS_PDF_ENGINE=auto

# Visual structure provider. heuristic is built-in; json merges external layout-model regions.
# command runs a local executable once per page. It receives page JSON on stdin and must print JSON regions on stdout.
PAPERLENS_VISUAL_PROVIDER=heuristic
PAPERLENS_VISUAL_PROVIDER_PATH=
PAPERLENS_VISUAL_PROVIDER_COMMAND=
PAPERLENS_VISUAL_PROVIDER_ARGS=[]
PAPERLENS_VISUAL_PROVIDER_TIMEOUT_MS=5000

# Persistence. Keep json for simple local use; run npm run storage:migrate:sqlite first before enabling sqlite.
PAPERLENS_STORAGE=json
PAPERLENS_SQLITE_PATH=./data/paperlens.sqlite

# Local OCR for scanned PDFs. Default is English; use eng+chi_sim for Chinese/English papers.
PAPERLENS_OCR_LANGUAGE=eng
PAPERLENS_OCR_TIMEOUT_SECONDS=1800

# Optional. Leave empty if your network can reach model APIs directly.
# macOS/Linux local service example:
# PAPERLENS_PROXY_URL=http://127.0.0.1:7897
#
# Docker Desktop example:
# PAPERLENS_PROXY_URL=http://host.docker.internal:7897
PAPERLENS_PROXY_URL=

# Optional model API keys. If set, PaperLens can use them without typing a Key in the web UI.
# UI-entered Keys and saved local key refs still take priority over environment keys.
PAPERLENS_KIMI_API_KEY=
PAPERLENS_KIMI_CODE_DIRECT_API_KEY=
PAPERLENS_KIMI_CODE_API_KEY=
PAPERLENS_MOONSHOT_API_KEY=
PAPERLENS_KIMI_PLATFORM_API_KEY=
PAPERLENS_DEEPSEEK_API_KEY=
PAPERLENS_OPENAI_API_KEY=
PAPERLENS_CUSTOM_API_KEY=
PAPERLENS_API_KEY=

# Optional. Kimi Code Direct does not need Claude CLI.
# Use only for the "Claude Code 本机配置" provider, or if Claude Code is installed in a non-standard location.
# PAPERLENS_CLAUDE_CLI=/opt/homebrew/bin/claude
PAPERLENS_CLAUDE_CLI=

# Optional. Off by default. Set to true only if you explicitly want the page Kimi Code Key
# to be routed through local Claude Code CLI instead of the direct Kimi Code API.
PAPERLENS_KIMI_CODE_USE_CLAUDE_CLI=false

# Analysis throughput. Defaults work for most users.
PAPERLENS_ANALYSIS_TARGET_MINUTES=20
PAPERLENS_ANALYSIS_BATCH_SIZE=12
PAPERLENS_ANALYSIS_CONCURRENCY=3
PAPERLENS_AGENT_ANALYSIS_BATCH_SIZE=8
PAPERLENS_AGENT_ANALYSIS_CONCURRENCY=2
PAPERLENS_ANALYSIS_FAILED_RETRY_BATCH_SIZE=2
